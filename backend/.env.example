# Copy to .env and fill in. .env is gitignored — never commit the real key.
#   cp .env.example .env && chmod 600 .env
# Paste the key with NO angle brackets and no quotes:
#   GEMINI_API_KEY=AQ.xxxxxxxx

# Google AI Studio key (aistudio.google.com). Leave empty to run fully offline:
# Thai queries then fall back to the built-in dictionary and matches keep CLIP's
# own ranking — search still works, just less accurately.
GEMINI_API_KEY=

# Vision-capable and lowest-latency; use gemini-3.5-flash if the re-rank needs a
# stronger judge.
GEMINI_MODEL=gemini-3.1-flash-lite

# Set to 0 to disable either LLM step without removing the key.
UPFOUND_LLM_TRANSLATE=1
UPFOUND_LLM_RERANK=1
