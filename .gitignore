# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# ---- Model weights (auto-downloaded by ultralytics / open_clip; too big for git) ----
*.pt
*.onnx
*.engine
mobileclip_blt.ts

# ---- EdgeAI generated output (regenerated on every run) ----
EdgeAI/out/crops/
EdgeAI/out/persons/
EdgeAI/out/*.mp4
EdgeAI/out/*.avi
EdgeAI/out/diag_*
EdgeAI/out/contact*
EdgeAI/out/_*
# runtime event stream (regenerated; grows large with embeddings)
EdgeAI/out/events.jsonl
# live web view snapshot + preview manifest (regenerated every run)
EdgeAI/out/live.jpg
EdgeAI/out/previews.txt

# ---- Backend runtime data (sqlite db + user uploads) ----
backend/data/

# ---- Public-deploy runtime logs (backend + cloudflare tunnel) ----
backend/.tunnel-*.log

# ---- Secrets (API keys) — never commit ----
# .env.bak / .env.local etc. hold the same key, so cover every variant.
.env
.env.*
*.env
*.env.*
!.env.example
!*.env.example

# ---- OS / editor junk ----
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
